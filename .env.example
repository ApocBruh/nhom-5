# ============================================================
# FILE: .env.example
# MỤC ĐÍCH: Mẫu file cấu hình environment
# CÁCH SỬ DỤNG: 
#   1. Copy file này thành .env
#   2. Cập nhật giá trị theo hệ thống của bạn
#   3. Commit .env vào .gitignore (không push lên repo)
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# Địa chỉ/hostname của MySQL server
# - localhost: MySQL chạy cùng máy
# - 127.0.0.1: IP address của localhost
# - 192.168.1.100: IP remote server (nếu MySQL ở server khác)
DB_HOST=localhost

# Port MySQL (mặc định: 3306)
# Chỉ thay đổi nếu MySQL của bạn chạy trên port khác
DB_PORT=3306

# User MySQL
# - root: User mặc định khi cài MySQL (có quyền cao nhất)
# - Bạn có thể tạo user riêng với quyền hạn chế hơn
DB_USER=root

# Password của MySQL user
# - Để trống nếu root không có password (mặc định trên local)
# - Nhập password nếu đã set khi cài MySQL
DB_PASSWORD=

# Tên database
# - doan_nodejs_nhom5: Database của do án này
DB_NAME=doan_nodejs_nhom5

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

# Port mà Node.js server sẽ chạy
# - 3000: Port mặc định
# - 8080, 5000: Các port khác
# - Tránh các port đặc biệt (80, 443, 22, v.v.)
PORT=3000

# NODE_ENV: Môi trường ứng dụng
# - development: Phát triển (logs chi tiết, auto-reload)
# - production: Sản xuất (tối ưu hóa, logs tối thiểu)
# - test: Testing
NODE_ENV=development

# ============================================================
# HƯỚNG DẪN CHI TIẾT
# ============================================================

# 🔧 Cách cấu hình cho các hệ thống khác nhau:

# 1️⃣ Windows (XAMPP):
#    - DB_HOST=localhost
#    - DB_USER=root
#    - DB_PASSWORD= (để trống nếu không set password)

# 2️⃣ Linux/Mac (MySQL từ Homebrew):
#    - DB_HOST=localhost
#    - DB_USER=root
#    - DB_PASSWORD=mysql (hoặc password bạn set)

# 3️⃣ Remote Server (AWS, DigitalOcean):
#    - DB_HOST=123.456.789.000 (IP public của server)
#    - DB_USER=app_user (user chuyên dùng cho app)
#    - DB_PASSWORD=secure_password_here

# ⚠️ BẢO MẬT:
# - KHÔNG BỎNG upload .env lên GitHub (thêm vào .gitignore)
# - KHÔNG share .env file với người khác
# - KHÔNG hardcode password trực tiếp trong code
# - Sử dụng .env để bảo vệ thông tin nhạy cảm
