<footer>
    <div class="footer-info">
        <!-- Yêu cầu: Truy xuất từ CSDL địa chỉ, email, facebook, youtube... -->
        <!-- Ghi chú: Hiện tại chúng ta dùng biến siteInfo (sẽ truyền từ app.js sang) để in ra -->
        <h3>Thông tin liên hệ</h3>
        <p><i class="fas fa-map-marker-alt"></i> <%= siteInfo.address %></p>
        <p><i class="fas fa-envelope"></i> <%= siteInfo.email %></p>
        <p><a href="<%= siteInfo.facebook %>" target="_blank"><i class="fab fa-facebook"></i> Facebook</a></p>
        <p><a href="<%= siteInfo.youtube %>" target="_blank"><i class="fab fa-youtube"></i> YouTube</a></p>
    </div>

    <div class="footer-subscribe">
        <!-- Yêu cầu: Nút subscribe nhận thông tin -->
        <h3>Đăng ký nhận tin tức mới</h3>
        <form action="/subscribe" method="POST">
            <input type="email" name="email" placeholder="Nhập email của bạn..." required>
            <button type="submit">Subscribe</button>
        </form>
    </div>
    <div class="copyright"><%= siteInfo.copyright %></div>
</footer>