<!-- ============================================================ -->
<!-- FILE: partials/header.ejs -->
<!-- MỤC ĐÍCH: Định nghĩa Header và Navigation của trang -->
<!-- MÔ TẢ: File này chứa: -->
<!-- 1. Topbar - Thanh thông tin trên cùng với ngày tháng và social icons -->
<!-- 2. Navbar - Menu điều hướng chính -->
<!-- Được nhúng vào đầu tất cả các trang -->
<!-- ============================================================ -->

<!-- Topbar Start -->
<!-- d-none d-lg-block: Ẩn trên mobile/tablet, chỉ hiện trên desktop (lg screens) -->
<!-- container-fluid: Chiếm 100% chiều rộng của viewport -->
<!-- ============================================================ -->
<div class="container-fluid d-none d-lg-block">
    <div class="row align-items-center bg-dark px-lg-5">
        <!-- CỘT 1 (9 cột): Hiển thị ngày tháng và menu thông tin -->
        <!-- col-lg-9: Chiếm 9/12 chiều rộng trên large screens (75%) -->
        <!-- ============================================================ -->
        <div class="col-lg-9">
            <nav class="navbar navbar-expand-sm bg-dark p-0">
                <ul class="navbar-nav ml-n2">
                    <!-- LI-1: Ngày hiện tại động -->
                    <!-- EJS templating: <%= ... %> cho phép chạy JavaScript và in kết quả -->
                    <!-- toLocaleDateString('en-US', {...}) định dạng ngày theo ngôn ngữ Anh -->
                    <!-- Kết quả ví dụ: "Wednesday, January 15, 2025" -->
                    <li class="nav-item border-right border-secondary">
                        <a class="nav-link text-body small" href="#"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></a>
                    </li>
                    <!-- LI-2 đến LI-4: Menu thông tin (Advertise, Contact, Login) -->
                    <!-- border-right: Đường viền phía bên phải -->
                    <!-- border-secondary: Màu viền (secondary color) -->
                    <!-- text-body: Màu chữ mặc định (thường là màu xám nhạt) -->
                    <!-- small: Font size nhỏ hơn -->
                    <li class="nav-item border-right border-secondary">
                        <a class="nav-link text-body small" href="#">Advertise</a>
                    </li>
                    <li class="nav-item border-right border-secondary">
                        <a class="nav-link text-body small" href="/contact">Contact</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-body small" href="#">Login</a>
                    </li>
                </ul>
            </nav>
        </div>

        <!-- CỘ 2 (3 cột): Social Media Icons -->
        <!-- col-lg-3: Chiếm 3/12 chiều rộng (25%) -->
        <!-- text-right: Căn chữ sang bên phải -->
        <!-- d-none d-md-block: Ẩn trên mobile, hiện trên medium screens trở lên -->
        <!-- ============================================================ -->
        <div class="col-lg-3 text-right d-none d-md-block">
            <nav class="navbar navbar-expand-sm bg-dark p-0">
                <ul class="navbar-nav ml-auto mr-n2">
                    <!-- Social media icons từ Font Awesome 5 -->
                    <!-- fa-twitter, fa-facebook-f, fa-youtube, v.v. -->
                    <!-- siteInfo.facebook và siteInfo.youtube được truyền từ app.js -->
                    <!-- target="_blank": Mở link trong tab mới -->
                    <li class="nav-item">
                        <a class="nav-link text-body" href="#"><small class="fab fa-twitter"></small></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-body" href="<%= siteInfo.facebook %>" target="_blank"><small class="fab fa-facebook-f"></small></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-body" href="#"><small class="fab fa-linkedin-in"></small></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-body" href="#"><small class="fab fa-instagram"></small></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-body" href="#"><small class="fab fa-google-plus-g"></small></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-body" href="<%= siteInfo.youtube %>" target="_blank"><small class="fab fa-youtube"></small></a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- HÀNG THỨ 2: Logo và Quảng cáo banner -->
    <!-- bg-white: Nền trắng (khác với nền tối ở hàng topbar) -->
    <!-- py-3: Padding vertical (top + bottom) -->
    <!-- px-lg-5: Padding horizontal trên large screens -->
    <!-- ============================================================ -->
    <div class="row align-items-center bg-white py-3 px-lg-5">
        <!-- Logo BizNews -->
        <!-- col-lg-4: Chiếm 4/12 chiều rộng trên desktop (1/3 màn hình) -->
        <!-- d-none d-lg-block: Ẩn trên mobile, chỉ hiện trên desktop -->
        <!-- navbar-brand: Styling đặc biệt cho brand/logo -->
        <div class="col-lg-4">
            <a href="/" class="navbar-brand p-0 d-none d-lg-block">
                <h1 class="m-0 display-4 text-uppercase text-primary">Biz<span class="text-secondary font-weight-normal">News</span></h1>
                <!-- display-4: Heading rất lớn (Bootstrap heading class) -->
                <!-- text-uppercase: Chữ hoa toàn bộ -->
                <!-- text-primary: Màu chữ primary (thường là xanh) -->
                <!-- text-secondary: Màu chữ secondary (thường là vàng/cam) -->
                <!-- font-weight-normal: Font weight bình thường (không đậm) -->
            </a>
        </div>

        <!-- Banner quảng cáo (728x90 pixels) -->
        <!-- col-lg-8: Chiếm 8/12 chiều rộng (2/3 màn hình) -->
        <!-- text-center text-lg-right: Căn giữa trên mobile, bên phải trên desktop -->
        <!-- img-fluid: Ảnh responsive (tỷ lệ không đổi, tự adjust kích cỡ) -->
        <div class="col-lg-8 text-center text-lg-right">
            <a href="https://htmlcodex.com"><img class="img-fluid" src="/img/ads-728x90.png" alt="Advertisement Banner"></a>
        </div>
    </div>
</div>
<!-- Topbar End -->


<!-- Navbar Start -->
<!-- container-fluid p-0: Chiếm toàn bộ chiều rộng, không có padding -->
<!-- p-0: Padding 0 (loại bỏ tất cả padding mặc định) -->
<!-- ============================================================ -->
<div class="container-fluid p-0">
    <!-- NAV bar chính -->
    <!-- navbar-expand-lg: Collapse menu khi < lg screen, expand khi >= lg -->
    <!-- bg-dark navbar-dark: Nền tối, style tối cho text/icons -->
    <!-- py-2 py-lg-0: Padding vertical = 2 trên mobile, 0 trên desktop -->
    <!-- px-lg-5: Padding horizontal = 5 trên desktop -->
    <!-- ============================================================ -->
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-2 py-lg-0 px-lg-5">
        <!-- LOGO trên mobile -->
        <!-- d-block d-lg-none: Hiện trên mobile, ẩn trên desktop -->
        <!-- navbar-brand: Styling cho brand/logo -->
        <a href="/" class="navbar-brand d-block d-lg-none">
            <h1 class="m-0 display-4 text-uppercase text-primary">Biz<span class="text-white font-weight-normal">News</span></h1>
        </a>

        <!-- MOBILE TOGGLE BUTTON (Hamburger menu) -->
        <!-- data-toggle="collapse": Bootstrap directive để toggle collapse element -->
        <!-- data-target="#navbarCollapse": ID của element sẽ được toggle -->
        <!-- Khi nhấp button này trên mobile, menu #navbarCollapse sẽ ẩn/hiện -->
        <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- COLLAPSE CONTAINER: Chứa menu items và search -->
        <!-- collapse: Dùng để collapse/expand content (CSS class) -->
        <!-- navbar-collapse: Styling cho phần collapse của navbar -->
        <!-- justify-content-between: Căn giữa, space-between (left menu - right search) -->
        <!-- id="navbarCollapse": ID để được toggle bởi button phía trên -->
        <div class="collapse navbar-collapse justify-content-between px-0 px-lg-3" id="navbarCollapse">
            <!-- Menu items (trái) -->
            <!-- navbar-nav: Container cho list navigation items -->
            <!-- mr-auto: Margin-right auto (đẩy sang trái) -->
            <!-- py-0: Padding vertical 0 -->
            <div class="navbar-nav mr-auto py-0">
                <!-- Nav items: Home, Category, Single News, Contact -->
                <!-- nav-item nav-link: Styling chuẩn cho menu item -->
                <!-- active: Highlight link hiện tại (có thể set động bằng server) -->
                <a href="/" class="nav-item nav-link active">Home</a>
                <a href="/category" class="nav-item nav-link">Category</a>
                <a href="/single" class="nav-item nav-link">Single News</a>
                <a href="/contact" class="nav-item nav-link">Contact</a>
            </div>

            <!-- SEARCH INPUT (phải) -->
            <!-- input-group: Bootstrap component để nhóm input + addon -->
            <!-- ml-auto: Margin-left auto (đẩy sang phải) -->
            <!-- d-none d-lg-flex: Ẩn trên mobile, hiện trên desktop -->
            <!-- width: 100%; max-width: 300px: Set chiều rộng nhưng không vượt 300px -->
            <div class="input-group ml-auto d-none d-lg-flex" style="width: 100%; max-width: 300px;">
                <!-- form-control: Input field chuẩn Bootstrap -->
                <!-- border-0: Loại bỏ border (nối liên tục với icon phía bên phải) -->
                <input type="text" class="form-control border-0" placeholder="Keyword">
                <!-- input-group-append: Phần addon (icon) bên phải input -->
                <!-- input-group-text: Styling cho text/icon addon -->
                <!-- bg-primary: Nền màu primary (xanh) -->
                <!-- text-dark: Chữ màu tối -->
                <!-- border-0: Không border -->
                <!-- px-3: Padding horizontal 3 -->
                <div class="input-group-append">
                    <button class="input-group-text bg-primary text-dark border-0 px-3"><i class="fa fa-search"></i></button>
                </div>
            </div>
        </div>
    </nav>
</div>
<!-- Navbar End -->