<!-- MỤC ĐÍCH: Main view/layout của trang chủ website -->
<!-- MÔ TẢ: File này là template chính chứa: -->
<!-- 1. HTML5 DOCTYPE và head (nhúng partials/head.ejs) -->
<!-- 2. Header/Navigation (nhúng partials/header.ejs) -->
<!-- 3. Main News Slider - Carousel bài viết featured -->
<!-- 4. Breaking News - Ticker tin mới -->
<!-- 5. Featured News - Slider tin nổi bật -->
<!-- 6. News With Sidebar - Bài viết chính + sidebar phụ -->
