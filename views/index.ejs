    <!-- ============================================================ -->
    <!-- PHẦN 8: JAVASCRIPT LIBRARIES - Nhập các thư viện JavaScript -->
    <!-- ============================================================ -->
    <!-- Thứ tự tải script rất quan trọng:
         1. jQuery (dependency cho Bootstrap, Owl Carousel)
         2. Bootstrap Bundle (UI components)
         3. Easing (animation smoothing)
         4. Owl Carousel (slider functionality)
         5. main.js (initialization code của ứng dụng)
    -->

    <!-- jQuery 3.4.1 từ CDN -->
    <!-- jQuery là JavaScript library giúp DOM manipulation, AJAX, events -->
    <!-- CDN: https://code.jquery.com (Content Delivery Network) -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>

    <!-- Bootstrap Bundle 4.4.1 từ CDN -->
    <!-- Bao gồm Bootstrap JavaScript + Popper.js (dependency cho dropdowns, tooltips) -->
    <!-- Cung cấp components: Navbar, Modal, Dropdown, Carousel, Toast, v.v. -->
    <!-- Ngôn ngữ: 'bundle' nghĩa là bao gồm Popper.js bên trong -->
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>

    <!-- Easing Animation Library (local file) -->
    <!-- Thư viện cung cấp các hàm easing cho smooth animations -->
    <!-- Ví dụ: easeInOutQuad, easeInOutCubic, v.v. -->
    <!-- Được sử dụng cho smooth scrolling effects -->
    <!-- Đường dẫn: /lib/easing/easing.min.js (phục vụ từ public/) -->
    <script src="/lib/easing/easing.min.js"></script>

    <!-- Owl Carousel 2.2.1 (local file) -->
    <!-- Plugin jQuery tạo responsive carousel/slider -->
    <!-- Được sử dụng cho:
         - Main News Slider
         - Breaking News Ticker
         - Featured News Carousel
    -->
    <!-- Đường dẫn: /lib/owlcarousel/owl.carousel.min.js (phục vụ từ public/) -->
    <script src="/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Main JavaScript (local file) -->
    <!-- File này chứa tất cả custom JavaScript code cho ứng dụng:
         - Khởi tạo Owl Carousel với config
         - Back-to-top button functionality
         - Dropdown menu handlers
         - Smooth scrolling
         - Custom animations
    -->
    <!-- Đường dẫn: /js/main.js (phục vụ từ public/) -->
    <script src="/js/main.js"></script>

    <!-- ============================================================ -->
    <!-- PHẦN 9: FOOTER - Nhúng partial footer -->
    <!-- ============================================================ -->
    <!-- <%- include(...) %>: EJS command để nhúng file partial -->
    <!-- '../partials/footer': Đường dẫn tương đối từ views/ tới partials/footer.ejs -->
    <!-- { siteInfo: siteInfo }: Truyền siteInfo object từ route vào footer partial -->
    <!-- Footer chứa: Contact info, Social links, Popular news, Categories, Newsletter -->
    <%- include('../partials/footer', { siteInfo: siteInfo }) %>
