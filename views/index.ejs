<!DOCTYPE html>
<html lang="en">
    <!-- PHẦN 1: HTML HEAD -->
    <!-- head: Chứa metadata, stylesheets, title, favicon, v.v. -->
    <!-- <%- include(...) %>: EJS command để nhúng file partial -->
    <!-- '../partials/head': Đường dẫn tương đối từ views/ tới partials/head.ejs -->
    <!-- { title: title }: Truyền biến title từ route (app.js) vào partial -->
<head>
    <%- include('../partials/head', { title: title }) %>
</head>

